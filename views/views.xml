<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- VISTA TREE/LIST -->
        <record id="resident_view_list" model="ir.ui.view">
            <field name="name">cs.resident.list</field>
            <field name="model">cs.resident</field>
            <field name="arch" type="xml">
                <list string="Residentes">
                    <field name="name" string="Nombre"/>
                    <field name="dni" string="DNI"/>
                    <field name="edad" string="Edad"/>
                    <field name="saldo" string="Saldo (€)"/>
                    <field name="state" string="Estado"/>
                </list>
            </field>
        </record>

        <!-- VISTA FORM -->
        <record id="resident_view_form" model="ir.ui.view">
            <field name="name">cs.resident.form</field>
            <field name="model">cs.resident</field>
            <field name="arch" type="xml">
                <form string="Residente">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <!-- SELECCIONAR CONTACTO O CREAR NUEVO -->
                        <group string="Origen del Residente" col="1">
                            <field name="partner_id" domain="[('category_id.name', 'ilike', 'Paciente')]" placeholder="Seleccionar contacto existente (etiqueta Paciente) O dejar vacío para crear nuevo"/>
                        </group>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Nombre Completo"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Datos Personales" col="2">
                                <field name="dni"/>
                                <field name="phone"/>
                                <field name="fecha_nacimiento"/>
                                <field name="edad"/>
                                <field name="weight_kg"/>
                                <field name="height_cm"/>
                                <field name="state" string="Estado del Residente"/>
                            </group>

                            <group string="Ubicación del Residente" col="2">
                                <field name="residence_id"/>
                                <field name="room_id" domain="[('residence_id', '=', residence_id)]"/>
                                <field name="current_stay_tipo" string="Modalidad Actual" readonly="1"/>
                            </group>

                            <group string="Datos Económicos" col="2" invisible="not tiene_wallet">
                                <field name="tiene_wallet" invisible="1"/>
                                <field name="wallet_id" invisible="1"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="saldo" readonly="1"/>
                            </group>
                        </group>

                        <group string="Trabajadores Asignados" col="1">
                            <field name="worker_ids" nolabel="1" widget="many2many_tags">
                            </field>
                        </group>

                        <group name="resident_notes_group" string="Observaciones" col="1">
                            <field name="notas" nolabel="1" placeholder="Notas y observaciones..."/>
                        </group>

                        <notebook>
                            <page string="Historial de Habitaciones" name="stay_ids">
                                <field name="stay_ids">
                                    <list string="Historial de Habitaciones" editable="bottom" create="0">
                                        <field name="residence_id" string="Residencia"/>
                                        <field name="room_id" string="Habitación"/>
                                        <field name="fecha_inicio" string="Fecha Inicio"/>
                                        <field name="fecha_fin" string="Fecha Fin"/>
                                        <field name="dias" string="Días"/>
                                        <field name="tipo" string="Modalidad" optional="hide"/>
                                        <field name="notas" string="Notas" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- VISTA SEARCH -->
        <record id="resident_view_search" model="ir.ui.view">
            <field name="name">cs.resident.search</field>
            <field name="model">cs.resident</field>
            <field name="arch" type="xml">
                <search string="Residentes">
                    <field name="name" string="Nombre"/>
                    <field name="dni" string="DNI"/>
                    <field name="state" string="Estado"/>
                    <separator/>
                    <filter name="filter_activos" string="Activos" domain="[('state', '=', 'activo')]"/>
                    <filter name="filter_pausados" string="Pausados" domain="[('state', '=', 'pausado')]"/>
                    <filter name="filter_alta" string="Alta" domain="[('state', '=', 'alta')]"/>
                    <filter name="filter_baja" string="Baja" domain="[('state', '=', 'baja')]"/>
                </search>
            </field>
        </record>

        <!-- ACCIÓN -->
        <record id="resident_action" model="ir.actions.act_window">
            <field name="name">Residentes</field>
            <field name="res_model">cs.resident</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cree el primer residente
                </p>
            </field>
        </record>

        <!-- MENÚ -->
        <menuitem id="cs_menu" name="Centro Sanitario" sequence="10" web_icon="cs_resident,static/description/icon.png"/>
        <menuitem id="cs_menu_resident" parent="cs_menu" name="Residentes" action="resident_action" sequence="10"/>

    </data>
</odoo>
