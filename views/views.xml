<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <record id="resident_view_list" model="ir.ui.view">
            <field name="name">cs.resident.list</field>
            <field name="model">cs.resident</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="dni"/>
                    <field name="edad"/>
                    <field name="saldo"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="resident_view_form" model="ir.ui.view">
            <field name="name">cs.resident.form</field>
            <field name="model">cs.resident</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="dni"/>
                            <field name="fecha_nacimiento"/>
                            <field name="edad"/>
                            <field name="phone"/>
                            <field name="state"/>
                            <field name="saldo"/>
                        </group>
                        <group>
                            <field name="notas"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="resident_action" model="ir.actions.act_window">
            <field name="name">Residentes</field>
            <field name="res_model">cs.resident</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="cs_menu" name="Centro Sanitario" sequence="10"/>
        <menuitem id="cs_menu_resident" parent="cs_menu" name="Residentes" action="resident_action" sequence="10"/>

    </data>
</odoo>
